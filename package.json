{
  "name": "project-w",
  "version": "1.0.0",
  "description": "WhatsApp-based campaign automation platform for instant predefined replies using WhatsApp Cloud API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "render-build": "npm run build && npm run db:migrate"
  },
  "keywords": [
    "whatsapp",
    "whatsapp-api",
    "campaign-automation",
    "auto-reply",
    "webhook",
    "nodejs",
    "typescript",
    "drizzle",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.27.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.18.2",
    "postgres": "^3.4.5"
  }
}
